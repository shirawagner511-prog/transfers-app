# Supabase project URL (found in: Project Settings > API > Project URL)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon public key (found in: Project Settings > API > anon public)
# This key is safe to use in the frontend.
# NEVER use the service_role key in the frontend.
VITE_SUPABASE_ANON_KEY=your-anon-key-here
